HOST=0.0.0.0
PORT=3000
SQLITE_PATH=./data/app.db
DATABASE_URL="file:../data/app.db"
TELEGRAM_BOT_TOKEN=123456:replace-with-bot-token
TELEGRAM_WEBHOOK_SECRET=replace-with-strong-secret
TELEGRAM_TRANSPORT=polling
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REFRESH_TOKEN=replace-with-google-refresh-token
GOOGLE_CALENDAR_ID=primary
ADMIN_TELEGRAM_ID=replace-with-admin-telegram-id
SENDGRID_API_KEY=replace-with-sendgrid-api-key
SENDGRID_FROM_EMAIL=replace-with-sender-email
SENDGRID_FROM_NAME=Meeting bot
BACKGROUND_JOBS_ENABLED=true
BACKGROUND_JOBS_POLL_MS=15000
BACKGROUND_JOBS_BATCH_SIZE=10
